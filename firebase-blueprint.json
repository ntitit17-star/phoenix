{
  "entities": {
    "University": {
      "title": "University",
      "description": "A higher educational institution in Georgia.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the university." },
        "name": { "type": "string", "description": "Official name of the university." },
        "logo": { "type": "string", "description": "URL of the university logo." },
        "type": { "type": "string", "enum": ["კერძო", "სახელმწიფო"], "description": "Private or State institution." },
        "city": { "type": "string", "description": "City where the university is located." },
        "address": { "type": "string", "description": "Physical address." },
        "phone": { "type": "string", "description": "Contact phone number." },
        "website": { "type": "string", "description": "Official website URL." },
        "priceRange": { "type": "string", "description": "Range of tuition fees." },
        "category": { "type": "string", "enum": ["უნივერსიტეტი", "კოლეჯი", "მართლმადიდებლური"], "description": "Category of the institution." },
        "faculties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "name", "logo", "type", "city", "address", "phone", "website", "priceRange", "category", "faculties"]
    },
    "News": {
      "title": "News",
      "description": "A news article or blog post.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the news item." },
        "title": { "type": "string", "description": "Headline of the news." },
        "content": { "type": "string", "description": "Full text of the article." },
        "image": { "type": "string", "description": "URL of the featured image." },
        "date": { "type": "string", "format": "date-time", "description": "Publication date." },
        "category": { "type": "string", "enum": ["სიახლე", "ბლოგი"], "description": "Type of content." },
        "author": { "type": "string", "description": "Author of the post." }
      },
      "required": ["id", "title", "content", "image", "date", "category"]
    }
  },
  "firestore": {
    "universities": {
      "schema": "University",
      "description": "Collection of all higher educational institutions."
    },
    "news": {
      "schema": "News",
      "description": "Collection of news and blog posts."
    }
  }
}
